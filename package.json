{
  "name": "social-link-tree",
  "version": "2024.11.21-21.02.15",
  "license": "MIT",
  "homepage": "https://codepen.io/AshleyWillis/pen/GRVVRwB",
  "scripts": {
    "build": "gulp -f ./build/gulpfile.js --cwd ./ --continue",
    "serve": "gulp serve -f ./build/gulpfile.js --cwd ./ --continue",
    "task": "gulp -f ./build/gulpfile.js --cwd ./ --continue",
    "tasks": "gulp --tasks-simple -f ./build/gulpfile.js --cwd ./ --continue"
  },
  "config": {
    "srcDir": "src/",
    "distDir": "dist/"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-modules-commonjs": "^7.29.7",
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "browser-sync": "^3.0.4",
    "del": "^4.1.1",
    "glob": "^7.1.4",
    "gulp": "^5.0.1",
    "gulp-babel": "^8.0.0",
    "gulp-inject-partials": "^1.0.5",
    "gulp-rename": "^1.4.0"
  },
  "browserslist": [
    "last 5 version"
  ],
  "tasks": {
    "partials": {
      "order": 999,
      "src": [
        "**/*.template.html"
      ],
      "pipe": [
        {
          "require": "gulp-inject-partials",
          "args": [
            {
              "removeTags": true,
              "quiet": true,
              "ignoreError": true
            }
          ]
        }
      ],
      "rename": {
        "find": ".template",
        "replace": ""
      },
      "cleanup": [
        "**/*.partial.html",
        "**/*.template.html"
      ]
    },
    "babel": {
      "src": [
        "**/*.js",
        "**/*.babel"
      ],
      "pipe": [
        {
          "require": "gulp-babel"
        }
      ],
      "cleanup": [
        "**/*.babel"
      ]
    }
  },
  "babel": {
    "plugins": [
      [
        "@babel/plugin-transform-modules-commonjs",
        {
          "strictMode": false
        }
      ],
      "@babel/plugin-transform-react-jsx"
    ]
  }
}
